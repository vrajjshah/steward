{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/alex/Documents", "/Users/alex/Projects"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "REPLACE_WITH_YOUR_TOKEN"
      }
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "REPLACE_WITH_YOUR_TOKEN",
        "SLACK_TEAM_ID": "REPLACE_WITH_YOUR_TEAM_ID"
      }
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://localhost/appdb"]
    },
    "web-fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "internal-billing": {
      "command": "node",
      "args": ["/opt/tools/billing-mcp/index.js"]
    }
  }
}
