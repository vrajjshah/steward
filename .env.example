# Copy to .env and fill in. Steward reads AWS credentials from the standard boto3
# chain (a Bedrock API key via AWS_BEARER_TOKEN_BEDROCK, or AWS_ACCESS_KEY_ID/SECRET).
AWS_REGION=us-east-1

# Bedrock model IDs. Any Converse-capable model works; defaults below match a
# tested OpenAI gpt-oss deployment on Amazon Bedrock. Swap for whatever you enable.
MODEL_SOL=openai.gpt-oss-120b-1:0
MODEL_TERRA=openai.gpt-oss-120b-1:0
MODEL_LUNA=openai.gpt-oss-20b-1:0

# Set STEWARD_DEMO=1 to serve the committed data/demo_results.json and never call Bedrock.
# STEWARD_DEMO=1
