# Copy to .env and fill in. Every backend uses the same MODEL_* tier contract.

# --- Backend selection -------------------------------------------------------
# bedrock            (default) Amazon Bedrock via the Converse API
# openai-compatible  any /v1/chat/completions endpoint (aliases: openai, ollama, local)
#
# Recommended default for security teams: a local endpoint (Ollama, vLLM,
# LM Studio) — the model tier then runs with no cloud account and no data
# egress. The deterministic tier never calls a model under any backend.
LLM_BACKEND=bedrock

# --- Local / OpenAI-compatible backend ---------------------------------------
# Base URL of the /v1 API. Default points at a local Ollama.
# LLM_BASE_URL=http://localhost:11434/v1
# Bearer token, only if the endpoint requires one (local Ollama does not).
# LLM_API_KEY=

# --- Bedrock backend ---------------------------------------------------------
# Steward reads AWS credentials from the standard boto3 chain (a Bedrock API
# key via AWS_BEARER_TOKEN_BEDROCK, or AWS_ACCESS_KEY_ID/SECRET).
AWS_REGION=us-east-1

# --- Model tiers (any backend) -----------------------------------------------
# Bedrock: model or inference-profile IDs. The defaults below match the tested
# open-weight OpenAI gpt-oss deployment; Anthropic Claude models are verified
# drop-ins (e.g. an Opus-class inference profile — Steward automatically omits
# sampling parameters for Claude models, which reject them).
# Local/OpenAI-compatible: model names/tags, e.g. MODEL_SOL=llama3.1:70b
MODEL_SOL=openai.gpt-oss-120b-1:0
MODEL_TERRA=openai.gpt-oss-120b-1:0
MODEL_LUNA=openai.gpt-oss-20b-1:0

# Set STEWARD_DEMO=1 to serve the committed data/demo_results.json and never call a model.
# STEWARD_DEMO=1
